{
  "ConnectionStrings": {
  
  },

  "AiAssistant": {
    "Provider": "Ollama",
    "Ollama": {
      "BaseUrl": "http://localhost:11434",
      "Model": "llama3.2",
      "TimeoutSeconds": 30,
      "FallbackToRuleBased": false
    },
    "RateLimit": {
      "PermitLimit": 10,
      "WindowSeconds": 60
    }
  },

  "Jwt": {
    "Issuer": "AiTicketingAssistant",
    "Audience": "AiTicketingAssistant",
    "SecretKey": "REPLACE_WITH_A_PRODUCTION_SECRET_KEY_AT_LEAST_32_BYTES",
    "ExpirationMinutes": 60
  },
  "SeedDemoUsers": true,
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
